      "parameters": {
        "jsCode": "const items = $input.all();\nconst wa_id = $(\"BuildContext\").first().json.wa_id;\n\n// Use rows from DB if available, otherwise provide fallback defaults\nlet menuRows = [];\nif (items.length > 0 && items[0].json.id) {\n  menuRows = items.map(i => ({\n    id: String(i.json.id).substring(0, 200),\n    title: String(i.json.title || \"Option\").substring(0, 24),\n    description: String(i.json.description || \"\").substring(0, 72)\n  }));\n} else {\n  // Fallback items if main_menu table is empty/missing\n  menuRows = [\n    { id: 'book_appt', title: '📅 Book Appointment', description: 'Schedule your visit' },\n    { id: 'treatments', title: '🦷 Our Treatments', description: 'Browse our services' },\n    { id: 'doctor', title: '📞 Talk to Doctor', description: 'Contact clinic' },\n    { id: 'timings', title: '⏰ Clinic Info', description: 'Location and Timings' }\n  ];\n}\n\nconst payload = {\n  messaging_product: \"whatsapp\",\n  to: wa_id,\n  type: \"interactive\",\n  interactive: {\n    type: \"list\",\n    header: { type: \"text\", text: \"Dental Care Clinic 🦷\" },\n    body: { text: \"How can I help you today? Please select an option below.\" },\n    footer: { text: \"Dental Care Clinic Pakistan\" },\n    action: {\n      button: \"View Menu\",\n      sections: [{\n        title: \"Main Menu\",\n        rows: menuRows.slice(0, 10)\n      }]\n    }\n  }\n};\n\nreturn [{ json: payload }];"
      },
