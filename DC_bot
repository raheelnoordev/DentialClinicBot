    {
      "parameters": {
        "jsCode": "const msg = $input.first().json;\n\n// 0. IGNORE SYSTEM NOTIFICATIONS (Delivered, Sent, etc.)\nif (!msg.msg_type && !msg.interactive_type && !msg.button_reply_id && !msg.text_body) {\n  return []; // Stop processing for empty or status webhooks\n}\n\nconst state = msg.state || 'IDLE';\nconst mt = msg.msg_type;\nlet bid = msg.button_reply_id || '';\nlet lid = msg.list_reply_id || '';\nlet lTitle = msg.list_reply_title || '';\nlet textBody = (msg.text_body || '').trim();\nlet bText = msg.button_text || '';\nlet bPayload = msg.button_payload || '';\n\nif(bPayload){ bid = bPayload; textBody = bText; }\n\nlet route = 'WELCOME';\nconst normTitle = String(lTitle + ' ' + textBody).toLowerCase();\n\n// 1. GREETING CHECK (Priority for Welcome Menu)\nconst greetings = ['hi', 'hello', 'hey', 'start', 'menu', 'aslam', 'asalam', 'salaam'];\nconst isGreeting = (mt === 'text' || mt === 'button') && (greetings.some(g => normTitle.split(/\\s+/).includes(g)) || textBody.length <= 3);\n\nconst isMenu = String(bid).toLowerCase().includes('menu') || \n               String(textBody).toLowerCase().includes('menu') || \n               String(bText).toLowerCase().includes('menu') || \n               String(bPayload).toLowerCase().includes('menu');\n\nconst isPositive = normTitle.includes('confirm') || normTitle.includes('yes') || bid === 'yes_confirm';\n\n// Time slot: title looks like \"10:00\" or \"14:30\"\nconst isTimeSlot = /^\\d{1,2}:\\d{2}/.test(lTitle.trim());\n\n// Main menu categories\nconst isMainMenuBook = normTitle.includes('book appointment') || normTitle.includes('book your');\nconst isMainMenuTreatments = normTitle === 'treatments' || normTitle === 'browse our services';\nconst isMainMenuDoctor = normTitle.includes('talk to doctor') || normTitle.includes('doctor contact');\nconst isMainMenuTimings = normTitle.includes('clinic timing') || normTitle.includes('location');\n\n// 2. TEXT/BUTTON HANDLING\nif (mt === 'text' || mt === 'button') {\n  if (isGreeting) {\n    route = 'WELCOME';\n  }\n  else if (state === 'AWAITING_NAME' || (state === 'IDLE' && textBody.length > 5 && !isMainMenuBook && !isMenu)) {\n     route = 'SAVE_NAME';\n  }\n  else if (state === 'CONFIRMING' && isPositive) route = 'SAVE_PHONE';\n  else if (bid === 'yes_confirm') route = 'SAVE_PHONE';\n  else if (isMenu) route = 'SHOW_MENU';\n  else if (normTitle.includes('book')) route = 'SHOW_TREATMENTS';\n  else if (normTitle.includes('doctor')) route = 'DOCTOR_CONTACT';\n  else if (normTitle.includes('timing') || normTitle.includes('location')) route = 'CLINIC_TIMINGS';\n  else if (normTitle.includes('cancel')) route = 'CANCEL';\n  else if (state === 'IDLE' && textBody.length > 3) {\n    route = 'GPT_RESPONSE'; // Default fallback for long text\n  }\n}\n\nif (mt === 'interactive') {\n  if (msg.interactive_type === 'button_reply') {\n    if (bid === 'yes_confirm') route = 'SAVE_PHONE';\n    else if (isMenu || bid === 'show_menu') route = 'SHOW_MENU';\n    else if (bid === 'view_treatments') route = 'SHOW_TREATMENTS';\n    else if (bid === 'cancel') route = 'CANCEL';\n    else if (bid === 'submit_contact') route = 'SAVE_NAME';\n  } else if (msg.interactive_type === 'list_reply') {\n    if (state === 'SELECTING_TREATMENT') route = 'SHOW_DATETIME';\n    else if (state === 'SELECTING_DATETIME') route = 'SHOW_CONFIRMATION';\n    else if (state === 'IDLE' || state === 'CONFIRMING' || state === 'AWAITING_NAME') {\n      if (isTimeSlot) route = 'SHOW_CONFIRMATION';\n      else if (isMainMenuBook) route = 'SHOW_TREATMENTS';\n      else if (isMainMenuDoctor) route = 'DOCTOR_CONTACT';\n      else if (isMainMenuTimings) route = 'CLINIC_TIMINGS';\n      else route = 'SHOW_DATETIME';\n    }\n  }\n}\n\nif (isMenu && route === 'WELCOME') route = 'SHOW_MENU';\n\nreturn [{json: {...msg, route}}];"
      },
