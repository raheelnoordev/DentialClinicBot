      "parameters": {
        "jsCode": "const items = $input.all();\nconst wa_id = $(\"BuildContext\").first().json.wa_id;\n\n// Filter for slots that are NOT booked\nconst availableItems = items.filter(i => {\n  const booked = i.json.booked;\n  if (booked === true || String(booked).toUpperCase() === \"TRUE\" || String(booked).trim() === \"1\") {\n    return false;\n  }\n  return !!i.json.time_label && !!i.json.id;\n});\n\n// If no available slots found\nif (availableItems.length === 0) {\n  const payload = {\n    messaging_product: \"whatsapp\",\n    to: wa_id,\n    type: \"text\",\n    text: { body: \"Sorry, all slots are currently booked! 🦷 Please check back later or call us directly.\" }\n  };\n  return [{ json: payload }];\n}\n\nconst groups = {};\navailableItems.forEach(i => {\n  const data = i.json;\n  const k = data.date_label || \"No Date\";\n  const day = data.day_name || \"\";\n  const time = data.time_label || \"No Time\";\n  const sid = data.id || \"slot\";\n\n  if (!groups[k]) groups[k] = { title: String(k + \" (\" + day + \")\").substring(0, 24), rows: [] };\n  if (groups[k].rows.length < 10) {\n    groups[k].rows.push({\n      id: String(sid).substring(0, 200),\n      title: String(time).substring(0, 24),\n      description: String(k + \", \" + day).substring(0, 72)\n    });\n  }\n});\n\nconst sections = Object.values(groups).slice(0, 10);\nconst payload = {\n  messaging_product: \"whatsapp\",\n  to: wa_id,\n  type: \"interactive\",\n  interactive: {\n    type: \"list\",\n    header: { type: \"text\", text: \"Select Date & Time 📅\" },\n    body: { text: \"Great! Please select your preferred date and time for the appointment.\" },\n    footer: { text: \"Dental Care Clinic Pakistan\" },\n    action: { button: \"Select Slot\", sections }\n  }\n};\n\nreturn [{ json: payload }];"
      },
